{
  "name": "@repo/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "concurrently -k \"pnpm run build:watch\" \"pnpm run start:dev\"",
    "start": "electron .",
    "start:dev": "wait-on file:dist/main.js tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "tsup": "^8.5.1"
  }
}
